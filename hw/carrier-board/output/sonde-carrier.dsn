(pcb "sonde-carrier.dsn"
  (parser
    (string_quote ")
    (space_in_quoted_tokens on)
    (host_cad "sonde-kicad")
    (host_version "0.4.0")
  )
  (resolution um 10)
  (unit um)
  (structure
    (layer F.Cu (type signal) (property (index 0)))
    (layer B.Cu (type signal) (property (index 1)))
    (boundary
      (path signal 0 0 0 25000 0 25000 35000 0 35000 0 0)
    )
    (via "Via[0-1]_600:300_um")
    (rule (width 250) (clearance 200))
  )
  (placement
    (component "Capacitor_SMD:C_0402_1005Metric"
      (place C2 14000 12000 front 0)
      (place C3 18000 18000 front 0)
    )
    (component "Capacitor_SMD:C_0805_2012Metric"
      (place C1 15000 6000 front 0)
    )
    (component "Connector_JST:JST_PH_S2B-PH-K_1x02_P2.00mm_Horizontal"
      (place J3 20000 3000 front 0)
    )
    (component "Connector_JST:JST_PH_S3B-PH-K_1x03_P2.00mm_Horizontal"
      (place J2 22000 33000 front 0)
    )
    (component "Connector_JST:JST_SH_SM04B-SRSS-TB_1x04-1MP_P1.00mm_Horizontal"
      (place J1 5000 32000 front 0)
    )
    (component "Connector_PinSocket_2.54mm:PinSocket_1x07_P2.54mm_Vertical"
      (place J6 3750 10500 front 0)
      (place J7 21250 10500 front 0)
    )
    (component "Inductor_SMD:L_0402_1005Metric"
      (place FB1 12000 6000 front 0)
    )
    (component "Package_TO_SOT_SMD:SOT-23"
      (place Q1 8000 12000 front 0)
    )
    (component "Resistor_SMD:R_0402_1005Metric"
      (place R1 11000 29000 front 0)
      (place R2 14000 29000 front 0)
      (place R3 15000 29000 front 0)
      (place R4 11000 12000 front 0)
      (place R5 12000 18000 front 0)
      (place R6 15000 18000 front 0)
    )
  )
  (library
    (image "Package_TO_SOT_SMD:SOT-23"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
      (pin Rect[T]Pad_600x600_um 3 0 2540)
    )
    (image "Inductor_SMD:L_0402_1005Metric"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
    )
    (image "Resistor_SMD:R_0402_1005Metric"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
    )
    (image "Capacitor_SMD:C_0805_2012Metric"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
    )
    (image "Capacitor_SMD:C_0402_1005Metric"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
    )
    (image "Connector_JST:JST_SH_SM04B-SRSS-TB_1x04-1MP_P1.00mm_Horizontal"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
      (pin Rect[T]Pad_600x600_um 3 0 2540)
      (pin Rect[T]Pad_600x600_um 4 0 3810)
    )
    (image "Connector_JST:JST_PH_S3B-PH-K_1x03_P2.00mm_Horizontal"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
      (pin Rect[T]Pad_600x600_um 3 0 2540)
    )
    (image "Connector_JST:JST_PH_S2B-PH-K_1x02_P2.00mm_Horizontal"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
    )
    (image "Connector_PinSocket_2.54mm:PinSocket_1x07_P2.54mm_Vertical"
      (pin Rect[T]Pad_600x600_um 1 0 0)
      (pin Rect[T]Pad_600x600_um 2 0 1270)
      (pin Rect[T]Pad_600x600_um 3 0 2540)
      (pin Rect[T]Pad_600x600_um 4 0 3810)
      (pin Rect[T]Pad_600x600_um 5 0 5080)
      (pin Rect[T]Pad_600x600_um 6 0 6350)
      (pin Rect[T]Pad_600x600_um 7 0 7620)
    )
    (padstack Via[0-1]_600:300_um
      (shape (circle F.Cu 600 0 0))
      (shape (circle B.Cu 600 0 0))
      (attach off)
    )
    (padstack Rect[T]Pad_600x600_um
      (shape (rect F.Cu -300 -300 300 300))
      (attach off)
    )
  )
  (network
    (net 1W_DATA
      (pins R3-1 J2-2 J6-2)
    )
    (net GND
      (pins J3-2 C1-2 C2-2 J1-1 J2-1 R6-2 C3-2 J7-6)
    )
    (net SCL
      (pins R2-1 J1-4 J6-6)
    )
    (net SDA
      (pins R1-1 J1-3 J6-5)
    )
    (net SENSOR_EN
      (pins Q1-1 R4-1 J6-3)
    )
    (net SENSOR_V
      (pins Q1-3 C2-1 R1-2 R2-2 J1-2 R3-2 J2-3 R5-1)
    )
    (net VBAT
      (pins J3-1 FB1-1 Q1-2 R4-2)
    )
    (net VBAT_FILT
      (pins FB1-2 C1-1 J6-7)
    )
    (net VBAT_SENSE
      (pins R5-2 R6-1 C3-1 J6-1)
    )
    (class Power VBAT VBAT_FILT SENSOR_V
      (circuit (use_via "Via[0-1]_600:300_um"))
      (rule (width 500) (clearance 200))
    )
    (class Default
      (circuit (use_via "Via[0-1]_600:300_um"))
      (rule (width 250) (clearance 200))
    )
  )
  (wiring)
)
