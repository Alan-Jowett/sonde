{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sonde board configuration",
  "type": "object",
  "required": ["mcu", "flash_size", "connectors", "power", "board", "pins"],
  "additionalProperties": false,
  "properties": {
    "mcu": {
      "type": "string",
      "enum": ["esp32-c3-mini-1"]
    },
    "flash_size": {
      "type": "integer",
      "enum": [4, 8, 16]
    },
    "connectors": {
      "type": "object",
      "required": ["qwiic"],
      "additionalProperties": false,
      "properties": {
        "qwiic": { "type": "integer", "minimum": 0, "maximum": 2 },
        "spi": { "type": "boolean" },
        "one_wire": { "type": "boolean" },
        "gpio_header": { "type": "boolean" },
        "battery": { "type": "boolean" }
      }
    },
    "sensors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "bus": { "type": "string" },
          "address": { "type": "string" }
        }
      }
    },
    "power": {
      "type": "object",
      "required": ["regulator", "regulator_part"],
      "additionalProperties": false,
      "properties": {
        "regulator": { "type": "string", "enum": ["ldo", "switching"] },
        "regulator_part": { "type": "string" },
        "sensor_gating": { "type": "boolean" },
        "sensor_gate_gpio": { "type": "integer" },
        "battery_monitor": { "type": "boolean" },
        "battery_adc_gpio": { "type": "integer" },
        "battery_divider_r_top": { "type": "integer" },
        "battery_divider_r_bot": { "type": "integer" }
      }
    },
    "board": {
      "type": "object",
      "required": ["size", "layers", "fab"],
      "additionalProperties": false,
      "properties": {
        "size": { "type": "string", "enum": ["compact", "standard"] },
        "layers": { "type": "integer", "enum": [2, 4] },
        "fab": { "type": "string", "enum": ["jlcpcb", "pcbway", "oshpark"] }
      }
    },
    "pins": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "i2c0_sda": { "type": "integer" },
        "i2c0_scl": { "type": "integer" },
        "usb_dp": { "type": "integer" },
        "usb_dm": { "type": "integer" },
        "sensor_pwr_en": { "type": "integer" },
        "sensor_pwr_en_active_low": { "type": "boolean" },
        "vbat_adc": { "type": "integer" },
        "boot_button": { "type": "integer" }
      }
    },
    "strapping": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "gpio_header_pins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pin", "net", "label"],
        "additionalProperties": false,
        "properties": {
          "pin": { "type": "integer" },
          "net": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    },
    "bom_overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "lcsc": { "type": "string" },
          "mpn": { "type": "string" }
        }
      }
    }
  }
}
