<?xml version="1.0" encoding="UTF-8"?>
<!--
  SPDX-License-Identifier: MIT
  Copyright (c) 2026 sonde contributors

  sonde.wxs — WiX v4 installer source for sonde-gateway + sonde-admin.

  Build prerequisites (all available via winget or Scoop):
    dotnet tool install -g wix -v 4.0.6
    wix extension add WixToolset.UI.wixext/4.0.6
    wix extension add WixToolset.Util.wixext/4.0.6

  Build command (from repository root, after a release build):
    dotnet build installer\windows\CustomActions\SondeCustomActions.csproj -c Release
    wix build installer\windows\sonde.wxs ^
         -d Version=VERSION ^
         -d GatewayBin=target\release\sonde-gateway.exe ^
         -d AdminBin=target\release\sonde-admin.exe ^
         -d CustomActionDll=installer\windows\CustomActions\bin\Release\net472\SondeCustomActions.dll ^
         -ext WixToolset.UI.wixext ^
         -ext WixToolset.Util.wixext ^
         -out sonde-x86_64.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="Sonde"
    Manufacturer="sonde contributors"
    Version="$(var.Version)"
    UpgradeCode="7B3A1E2C-4F5D-4A6B-8C9D-0E1F2A3B4C5D"
    Language="1033"
    Codepage="1252"
    InstallerVersion="500"
    Compressed="yes"
    Scope="perMachine">

    <SummaryInformation Keywords="Installer" Description="Sonde gateway and admin tools installer" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Sonde is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" />

    <!-- ── MSI properties ────────────────────────────────────────────── -->
    <!-- COM port for the ESP-NOW modem. Auto-detected by custom action
         or entered manually by the operator. Marked Secure so the value
         flows from the UI sequence to the execute sequence. -->
    <Property Id="MODEM_PORT" Value="" Secure="yes" />

    <!-- ── Feature tree ──────────────────────────────────────────────── -->
    <Feature Id="ProductFeature" Title="Sonde" Level="1">
      <ComponentGroupRef Id="BinariesGroup" />
      <ComponentGroupRef Id="ConfigGroup" />
    </Feature>

    <!-- ── Directory tree ───────────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLDIR" Name="Sonde">
        <Directory Id="BinDir" Name="bin" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATADIR" Name="sonde" />
    </StandardDirectory>

    <!-- ── Components ───────────────────────────────────────────────── -->
    <ComponentGroup Id="BinariesGroup" Directory="BinDir">
      <Component Id="GatewayExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="GatewayExeFile"
              Source="$(var.GatewayBin)"
              Name="sonde-gateway.exe"
              KeyPath="yes" />
        <!-- GW-1501: Register gateway as an auto-start Windows service.
             ServiceInstall is in the same component as the executable so
             the service binary path is correct and the component has a
             valid KeyPath. The service is NOT auto-started during install
             because the operator may need to generate a master key first
             (sonde-admin generate-key). Use "sc start sonde-gateway" or
             reboot after setup. -->
        <ServiceInstall Id="SondeGatewayService"
                        Name="sonde-gateway"
                        DisplayName="Sonde Gateway"
                        Description="Manages sensor nodes over ESP-NOW radio."
                        Start="auto"
                        Type="ownProcess"
                        ErrorControl="normal"
                        Arguments="--service --port [MODEM_PORT] --db [CommonAppDataFolder]sonde\gateway.db --master-key-file [CommonAppDataFolder]sonde\master-key.hex" />
        <!-- Stop service on uninstall and upgrade; do NOT start during
             install (operator must generate master key first). -->
        <ServiceControl Id="SondeGatewayControl"
                        Name="sonde-gateway"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
      <Component Id="AdminExe" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="AdminExeFile"
              Source="$(var.AdminBin)"
              Name="sonde-admin.exe"
              KeyPath="yes" />
        <!-- GW-1500: Add bin directory to system PATH -->
        <Environment Id="PATH"
                     Name="PATH"
                     Value="[BinDir]"
                     Separator=";"
                     Action="set"
                     Part="last"
                     System="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ConfigGroup" Directory="DATADIR">
      <!-- GW-1501 AC5: Create %ProgramData%\sonde\ config directory -->
      <Component Id="DataDirComp" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <CreateFolder />
      </Component>
    </ComponentGroup>

    <!-- ── Custom action: auto-detect ESP32-S3 modem COM port ────────
         GW-1501 AC2: Scans USB devices for VID 303A / PID 1001 and
         pre-populates the MODEM_PORT property. Runs early in the UI
         sequence (before CostFinalize) so the value is available if a
         custom dialog is added later. -->
    <Binary Id="SondeCustomActionsDll" SourceFile="$(var.CustomActionDll)" />
    <CustomAction Id="DetectModemPort"
                  BinaryRef="SondeCustomActionsDll"
                  DllEntry="DetectModemPort"
                  Execute="immediate"
                  Return="check" />

    <InstallUISequence>
      <Custom Action="DetectModemPort" Before="CostFinalize" />
    </InstallUISequence>

    <!-- ── UI ───────────────────────────────────────────────────────── -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
    <WixVariable Id="WixUILicenseRtf" Value="installer\windows\license.rtf" />

  </Package>
</Wix>
