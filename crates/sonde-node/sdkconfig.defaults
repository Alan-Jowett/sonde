#
# Default SDK configuration for the sonde-node ESP32-C3 firmware.
# Optimised for QEMU smoke testing while remaining compatible with real hardware.

# Flash configuration — must match the QEMU MTD drive (DIO mode, 40 MHz, 4 MB).
CONFIG_ESPTOOLPY_FLASHMODE_DIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_40M=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Use the built-in "Single factory app (large), no OTA" partition table.
# This provides ~1.5 MB for the app partition (vs 1 MB in the default).
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

# Serial console on UART0 at 115200 bps (QEMU forwards UART0 to stdio).
# Explicitly disable USB Serial/JTAG console so UART0 is used in QEMU.
# On ESP32-C3, the secondary USB Serial/JTAG console is enabled by
# Kconfig default; the pairing mode driver detects and reuses it.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_NUM=0
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG_ENABLED=n

# Log level: INFO captures the boot-marker lines the smoke test asserts on.
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Size optimizations — reduce firmware binary size.
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_COMPILER_OPTIMIZATION_ASSERTIONS_SILENT=y

# Main task stack size — increased from default (3584) to accommodate
# NVS, ESP-NOW, BPF interpreter, and BLE pairing initialization.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384

# FreeRTOS tick rate — pinned to 1000 Hz (1 ms/tick).
# The ESP pairing serial driver's ms_to_ticks() depends on this value.
CONFIG_FREERTOS_HZ=1000

# Disable unused WiFi features to reduce binary size.
# The node only needs STA mode for ESP-NOW.
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n
CONFIG_ESP_WIFI_ENTERPRISE_SUPPORT=n
